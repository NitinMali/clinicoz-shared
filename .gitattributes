# Normalize line endings to LF in the repo, checkout as OS-native
* text=auto

# Force LF for these file types (consistent across Windows/Mac/Linux)
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.hbs text eol=lf
*.html text eol=lf
*.css text eol=lf
*.env text eol=lf
*.gitkeep text eol=lf

# Binary files — don't touch
*.png binary
*.jpg binary
*.pdf binary
*.zip binary
