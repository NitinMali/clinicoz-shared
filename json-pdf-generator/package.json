{
  "name": "json-to-pdf-generator",
  "version": "1.0.0",
  "description": "NestJS module that converts structured JSON into formatted PDF documents",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node dist/src/main.js",
    "start:dev": "tsc --watch & node --watch dist/src/main.js",
    "start:local": "tsc && node dist/src/main.js",
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs');const p=require('path');function cpR(s,d){fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>{const sp=p.join(s,f),dp=p.join(d,f);fs.statSync(sp).isDirectory()?cpR(sp,dp):fs.copyFileSync(sp,dp)})};cpR('src/template','dist/template');cpR('src/template','dist/src/template')\"",
    "test": "jest --run",
    "test:watch": "jest",
    "lambda:build": "npm run build && cp -r src/template dist/template && cp -r templates dist/../templates",
    "lambda:deploy": "node scripts/deploy-lambda.js",
    "lambda:deploy:qa": "node scripts/deploy-lambda.js qa",
    "lambda:deploy:staging": "node scripts/deploy-lambda.js staging",
    "lambda:deploy:prod": "node scripts/deploy-lambda.js prod",
    "lambda:setup-api": "node scripts/setup-api-gateway.js",
    "lambda:setup-api:qa": "node scripts/setup-api-gateway.js qa",
    "lambda:setup-api:staging": "node scripts/setup-api-gateway.js staging",
    "lambda:setup-api:prod": "node scripts/setup-api-gateway.js prod"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1031.0",
    "@nestjs/common": "^9.0.0",
    "@nestjs/core": "^9.0.0",
    "@sparticuz/chromium": "^147.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^17.4.2",
    "handlebars": "^4.7.9",
    "puppeteer-core": "^24.41.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/platform-express": "^9.0.0",
    "@nestjs/testing": "^9.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^18.0.0",
    "@types/supertest": "^2.0.0",
    "@types/uuid": "^9.0.0",
    "fast-check": "^3.0.0",
    "jest": "^29.0.0",
    "supertest": "^6.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
